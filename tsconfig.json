{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ES2020",
    "moduleResolution": "bundler",
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    
    "allowJs": true,
    "checkJs": false,
    "strict": true,
    "noImplicitAny": false,
    "strictNullChecks": true,
    
    "outDir": "./dist",
    "rootDir": ".",
    "removeComments": true,
    "sourceMap": true,
    
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    
    "declaration": true,
    "declarationDir": "./dist/types",
    
    "resolveJsonModule": true,
    "allowImportingTsExtensions": true,
    "noEmit": true,
    "paths": {
      "fusee-framework": ["./framework/types/index.d.ts"],
      "fusee-framework/*": ["./framework/*"]
    }
  },
  "include": [
    "app/**/*",
    "framework/**/*",
    "auto-imports.d.ts"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "**/*.test.ts",
    "**/*.spec.ts"
  ]
}
